# Optional for local development: if unset, "pnpm dev" falls back to a local SQLite database
# (see scripts/setup-local-dev-db.mjs). Required in production — the app fails to start without it.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ephemeral secret with a console warning if this is left unset.
AUTH_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials).
# Optional locally — without them the Google sign-in button will fail, but
# email+password (Credentials) sign-in keeps working.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
